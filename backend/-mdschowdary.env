# Soil2Crop Backend Environment Variables
# Production Configuration

# MongoDB Atlas Connection (REQUIRED)
# Get your connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/soil2crop?retryWrites=true&w=majority

# Alternative for local development with memory DB
USE_MEMORY_DB=true

# Twilio Credentials (OPTIONAL - for SMS alerts)
# Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Server Configuration
PORT=3000
CORS_ORIGIN=["http://localhost:5173","http://localhost:8080","http://localhost:3000"]
NODE_ENV=production

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# File Upload Limits
MAX_FILE_SIZE=10485760

# Session/JWT Configuration (for future auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
